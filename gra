<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<meta name="theme-color" content="#111111"/>
<title>Paleta Smart Route — tablet</title>
<style>
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{margin:0;height:100%;font-family:Arial,Helvetica,sans-serif;background:#111;color:#111;overflow:hidden}
#app{height:100vh;height:100dvh;display:flex;flex-direction:column;background:#f5f2ea}
.top{background:linear-gradient(135deg,#111,#2b1600);color:#fff;padding:14px 16px;border-bottom:5px solid #f37021;flex-shrink:0}
.top h1{margin:0;font-size:21px;text-transform:uppercase;letter-spacing:.2px}
.top p{margin:5px 0 0;font-size:12px;color:#eee}
.status{display:flex;gap:8px;align-items:center;margin-top:8px;font-size:12px;font-weight:900;color:#ffd400}
.dot{width:11px;height:11px;border-radius:50%;background:#777}
.dot.on{background:#4CAF50;box-shadow:0 0 0 4px rgba(76,175,80,.18)}
.main{flex:1;overflow:hidden;display:flex;flex-direction:column}
.screen{display:none;flex:1;overflow:auto;padding:12px}
.screen.active{display:block}
.card{background:#fff;border:2px solid #d8d4ca;border-left:8px solid #f37021;border-radius:10px;padding:13px;margin-bottom:10px;box-shadow:0 2px 0 rgba(0,0,0,.08)}
.card.red{border-left-color:#d71920}
h2{font-size:19px;margin:0 0 8px}
.small{font-size:13px;color:#555;line-height:1.35}
.big{font-size:32px;line-height:1;font-weight:1000;color:#d71920}
input{width:100%;padding:14px;border:2px solid #ccc;border-radius:8px;font-size:21px;font-weight:900}
button{border:0;border-radius:8px;padding:14px 12px;font-size:15px;font-weight:1000;text-transform:uppercase;background:linear-gradient(90deg,#f37021,#ffd400);color:#111;box-shadow:0 3px 0 rgba(0,0,0,.25)}
button.full{width:100%;margin-top:9px}
button.dark{background:#111;color:#ffd400}
button.red{background:linear-gradient(90deg,#d71920,#f37021);color:#fff}
.row{display:flex;gap:8px}
.row button{flex:1}
.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.stat{background:#111;color:#ffd400;border-radius:8px;padding:11px;text-align:center;font-weight:1000;font-size:20px}
.stat span{display:block;color:#fff;font-size:11px;margin-top:3px}
.map{height:315px;background:#ddd;border:4px solid #111;border-radius:12px;position:relative;overflow:hidden;background-image:linear-gradient(90deg,rgba(0,0,0,.06) 1px,transparent 1px),linear-gradient(rgba(0,0,0,.06) 1px,transparent 1px);background-size:24px 24px}
.entrance{position:absolute;left:38%;bottom:2%;width:24%;height:24px;background:#111;color:#ffd400;text-align:center;font-size:11px;font-weight:900;padding-top:5px;border-radius:6px 6px 0 0}
.shelf{position:absolute;width:26%;height:70px;background:#fff;border:3px solid #111;border-left:8px solid #f37021;border-radius:8px;padding:7px;font-size:12px;font-weight:1000;text-align:center}
.shelf.active{outline:5px solid #ffd400;background:#fff4b8}
.shelf.done{background:#e8f5e9;opacity:.75}
.path{position:absolute;left:0;top:0;width:100%;height:100%;pointer-events:none}
.path line{stroke:#d71920;stroke-width:5;stroke-linecap:round;stroke-dasharray:10 8}
.path circle{fill:#d71920}
.pallet{height:210px;background:#c28b52;border:5px solid #6f431d;border-radius:10px;position:relative;overflow:hidden;margin-top:8px}
.box{position:absolute;background:#fff;border:2px solid #111;border-radius:4px;text-align:center;font-size:9px;font-weight:900;display:flex;align-items:center;justify-content:center;box-shadow:2px 2px 0 rgba(0,0,0,.25)}
.box.done{opacity:.25}
.box.philips{background:#fff6d6}.box.ledvance{background:#e3f2fd}.box.specjalne{background:#ffe6e6}.box.radium{background:#e8f5e9}
.progress{height:19px;background:#ddd;border-radius:30px;overflow:hidden;border:1px solid #aaa}
.bar{height:100%;background:linear-gradient(90deg,#f37021,#ffd400);width:0%}
.eanbox{background:#111;color:#ffd400;border-radius:8px;padding:10px;font-family:monospace;font-size:18px;font-weight:1000;text-align:center;margin:8px 0}
.product{border:1px solid #ddd;background:#fafafa;border-radius:8px;padding:9px;margin:7px 0}
.product.done{background:#e8f5e9;opacity:.65}
.product.next{outline:3px solid #ffd400;background:#fff8cf}
.toast{position:fixed;left:50%;bottom:16px;transform:translateX(-50%);z-index:30;background:#111;color:#ffd400;border:2px solid #ffd400;border-radius:12px;padding:12px 16px;font-weight:1000;display:none;max-width:92%;text-align:center}
.nav{display:flex;gap:1px;background:#111;border-top:4px solid #ffd400;flex-shrink:0}
.nav button{flex:1;border-radius:0;box-shadow:none;background:#222;color:#fff;font-size:11px;padding:11px 4px}
.nav button.active{background:#ffd400;color:#111}
.warning{background:#fff0f0;border:2px solid #d71920;color:#8b1010;border-radius:8px;padding:10px;font-weight:900;margin-top:8px;display:none}
@media(min-width:700px){
  #app{max-width:900px;margin:auto}
  .screen{padding:18px}
  .tablet-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:12px}
  .map{height:430px}
}
</style>
</head>
<body>
<div id="app">
  <div class="top">
    <h1>Paleta Smart Route</h1>
    <p>Tablet tutorial — paleta → EAN z góry → regał → kontrola błędów</p>
    <div class="status"><span class="dot" id="micDot"></span><span id="micStatus">Mikrofon wyłączony</span></div>
  </div>

  <div class="main">
    <section id="start" class="screen active">
      <div class="card red">
        <h2>Rozpocznij grę</h2>
        <p class="small">Apka będzie gadać do pracownika od początku. Najpierw poprosi o numer palety, potem o pierwszy EAN z góry palety.</p>
        <button class="full red" onclick="startGame()">Rozpocznij grę</button>
      </div>
      <div class="card">
        <h2>Numer palety</h2>
        <input id="palletNo" value="PAL-TUTORIAL-3000" onkeydown="if(event.key==='Enter')loadPallet()"/>
        <button class="full" onclick="loadPallet()">Wczytaj paletę</button>
      </div>
      <div class="card">
        <h2>Zasada</h2>
        <p class="small">Nie jedziemy ślepo po trasie. Pracownik podaje EAN z góry palety, żeby nie rozkładać całej palety. Apka prowadzi do regału tego EAN-u i pilnuje, żeby nie mieszać regałów.</p>
      </div>
    </section>

    <section id="mapScreen" class="screen">
      <div class="tablet-grid">
        <div class="card">
          <h2>Wirtualny sklep z góry</h2>
          <div class="map" id="storeMap">
            <svg class="path" id="pathSvg" viewBox="0 0 100 100" preserveAspectRatio="none"></svg>
            <div class="entrance">START</div>
          </div>
        </div>
        <div>
          <div class="card">
            <h2>Paleta</h2>
            <div class="grid">
              <div class="stat" id="leftUnits">3000<span>sztuk zostało</span></div>
              <div class="stat" id="leftEans">0<span>EAN zostało</span></div>
              <div class="stat" id="cartons">0<span>kartonów</span></div>
              <div class="stat">4<span>regały</span></div>
            </div>
            <div class="pallet" id="palletVisual"></div>
          </div>
        </div>
      </div>
    </section>

    <section id="work" class="screen">
      <div class="tablet-grid">
        <div>
          <div class="card red">
            <h2>Aktualne zadanie</h2>
            <div class="progress"><div class="bar" id="bar"></div></div>
            <p class="small" id="progressText">Postęp: 0%</p>
            <div id="task"></div>
            <div class="warning" id="warning"></div>
            <div class="row">
              <button class="red" onclick="toggleMic()" id="micBtn">Włącz mikrofon</button>
              <button onclick="demoSayNext()">Demo: powiedz dobry EAN</button>
            </div>
            <button class="full dark" onclick="demoSayWrong()">Demo: powiedz EAN z innego regału</button>
          </div>
        </div>
        <div class="card">
          <h2>Towary na aktualnym regale</h2>
          <div id="currentList"></div>
        </div>
      </div>
    </section>

    <section id="summary" class="screen">
      <div class="card red">
        <h2>Koniec palety</h2>
        <div class="big">MISJA WYKONANA</div>
        <p class="small" id="summaryText"></p>
        <button class="full" onclick="resetAll()">Reset demo</button>
      </div>
    </section>
  </div>

  <div class="nav">
    <button onclick="show('start')">Start</button>
    <button onclick="show('mapScreen')">Mapa</button>
    <button onclick="show('work')">Praca</button>
    <button onclick="show('summary')">Koniec</button>
  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const PALLET_ITEMS = [{"id": 1, "ean": "4306517600000", "name": "Philips LED produkt 1", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 1, "cartonSize": 6, "cartons": 3, "qty": 18, "done": false}, {"id": 2, "ean": "4306517600037", "name": "Ledvance produkt 2", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 5, "cartonSize": 36, "cartons": 3, "qty": 108, "done": false}, {"id": 3, "ean": "4306517600074", "name": "Specjalne produkt 3", "shelf": "Specjalne", "shelfKey": "specjalne", "x": 10, "y": 64, "position": 61, "cartonSize": 6, "cartons": 4, "qty": 24, "done": false}, {"id": 4, "ean": "4306517600111", "name": "Radium produkt 4", "shelf": "Radium", "shelfKey": "radium", "x": 63, "y": 64, "position": 25, "cartonSize": 48, "cartons": 3, "qty": 144, "done": false}, {"id": 5, "ean": "4306517600148", "name": "Philips LED produkt 5", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 8, "cartonSize": 6, "cartons": 2, "qty": 12, "done": false}, {"id": 6, "ean": "4306517600185", "name": "Ledvance produkt 6", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 17, "cartonSize": 24, "cartons": 5, "qty": 120, "done": false}, {"id": 7, "ean": "4306517600222", "name": "Specjalne produkt 7", "shelf": "Specjalne", "shelfKey": "specjalne", "x": 10, "y": 64, "position": 3, "cartonSize": 12, "cartons": 2, "qty": 24, "done": false}, {"id": 8, "ean": "4306517600259", "name": "Radium produkt 8", "shelf": "Radium", "shelfKey": "radium", "x": 63, "y": 64, "position": 51, "cartonSize": 36, "cartons": 1, "qty": 36, "done": false}, {"id": 9, "ean": "4306517600296", "name": "Philips LED produkt 9", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 1, "cartonSize": 36, "cartons": 1, "qty": 36, "done": false}, {"id": 10, "ean": "4306517600333", "name": "Ledvance produkt 10", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 24, "cartonSize