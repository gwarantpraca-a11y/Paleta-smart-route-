 63, "y": 64, "position": 51, "cartonSize": 36, "cartons": 6, "qty": 216, "done": false}, {"id": 21, "ean": "4306517600740", "name": "Philips LED produkt 21", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 44, "cartonSize": 48, "cartons": 4, "qty": 192, "done": false}, {"id": 22, "ean": "4306517600777", "name": "Ledvance produkt 22", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 35, "cartonSize": 36, "cartons": 3, "qty": 108, "done": false}, {"id": 23, "ean": "4306517600814", "name": "Specjalne produkt 23", "shelf": "Specjalne", "shelfKey": "specjalne", "x": 10, "y": 64, "position": 14, "cartonSize": 6, "cartons": 6, "qty": 36, "done": false}, {"id": 24, "ean": "4306517600851", "name": "Radium produkt 24", "shelf": "Radium", "shelfKey": "radium", "x": 63, "y": 64, "position": 64, "cartonSize": 6, "cartons": 4, "qty": 24, "done": false}, {"id": 25, "ean": "4306517600888", "name": "Philips LED produkt 25", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 13, "cartonSize": 24, "cartons": 2, "qty": 48, "done": false}, {"id": 26, "ean": "4306517600925", "name": "Ledvance produkt 26", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 24, "cartonSize": 24, "cartons": 5, "qty": 120, "done": false}, {"id": 27, "ean": "4306517600962", "name": "Specjalne produkt 27", "shelf": "Specjalne", "shelfKey": "specjalne", "x": 10, "y": 64, "position": 44, "cartonSize": 6, "cartons": 6, "qty": 36, "done": false}, {"id": 28, "ean": "4306517600999", "name": "Radium produkt 28", "shelf": "Radium", "shelfKey": "radium", "x": 63, "y": 64, "position": 25, "cartonSize": 36, "cartons": 5, "qty": 180, "done": false}, {"id": 29, "ean": "4306517601036", "name": "Philips LED produkt 29", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 44, "cartonSize": 6, "cartons": 2, "qty": 12, "done": false}, {"id": 30, "ean": "4306517601073", "name": "Ledvance produkt 30", "shelf": "Ledvance", "shelfKey": "ledvance", "x": 63, "y": 18, "position": 17, "cartonSize": 6, "cartons": 6, "qty": 36, "done": false}, {"id": 31, "ean": "4306517601110", "name": "Specjalne produkt 31", "shelf": "Specjalne", "shelfKey": "specjalne", "x": 10, "y": 64, "position": 14, "cartonSize": 6, "cartons": 3, "qty": 18, "done": false}, {"id": 32, "ean": "4306517601147", "name": "Radium produkt 32", "shelf": "Radium", "shelfKey": "radium", "x": 63, "y": 64, "position": 51, "cartonSize": 36, "cartons": 5, "qty": 180, "done": false}, {"id": 33, "ean": "4306517601184", "name": "Philips LED produkt 33", "shelf": "Philips LED", "shelfKey": "philips", "x": 10, "y": 18, "position": 13, "cartonSize": 6, "cartons": 6, "qty": 36, "done": false}];
const SHELVES = [{"key": "philips", "name": "Philips LED", "x": 10, "y": 18, "positions": [1, 8, 13, 21, 44, 58, 69]}, {"key": "ledvance", "name": "Ledvance", "x": 63, "y": 18, "positions": [5, 12, 17, 24, 35, 41, 52]}, {"key": "specjalne", "name": "Specjalne", "x": 10, "y": 64, "positions": [3, 14, 29, 44, 61, 69]}, {"key": "radium", "name": "Radium", "x": 63, "y": 64, "positions": [7, 18, 25, 36, 51, 64]}];
let currentShelfKey=null;
let started=false;
let scannedCount=0;
let listening=false, recognition=null, restartTimer=null;
const SR=window.SpeechRecognition||window.webkitSpeechRecognition;

function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  const order=['start','mapScreen','work','summary'];
  document.querySelectorAll('.nav button').forEach((b,i)=>b.classList.toggle('active',order[i]===id));
}

function startGame(){
  speak('Rozpoczynamy grę. Podaj numer palety.');
  show('start');
  document.getElementById('palletNo').focus();
}

function loadPallet(){
  started=true;
  currentShelfKey=null;
  scannedCount=0;
  PALLET_ITEMS.forEach(x=>x.done=false);
  renderAll();
  speak('Paleta wczytana. Rozplanowałem trasę na sklepie. Podaj pierwszy EAN z góry palety.');
  toast('Paleta wczytana. Trasa gotowa.');
  show('mapScreen');
}

function grouped(){
  const g={};
  PALLET_ITEMS.forEach(it=>{
    if(!g[it.shelfKey])g[it.shelfKey]={key:it.shelfKey,name:it.shelf,items:[],qty:0,x:it.x,y:it.y};
    g[it.shelfKey].items.push(it);
    g[it.shelfKey].qty+=it.qty;
  });
  return Object.values(g);
}

function renderAll(){
  renderStats();
  renderMap();
  renderPallet();
  renderTask();
}

function renderStats(){
  const left=PALLET_ITEMS.filter(x=>!x.done);
  const leftQty=left.reduce((s,x)=>s+x.qty,0);
  const cartonCount=PALLET_ITEMS.reduce((s,x)=>s+x.cartons,0);
  document.getElementById('leftUnits').innerHTML=leftQty+'<span>sztuk zostało</span>';
  document.getElementById('leftEans').innerHTML=left.length+'<span>EAN zostało</span>';
  document.getElementById('cartons').innerHTML=cartonCount+'<span>kartonów</span>';
  const pct=Math.round((3000-leftQty)/3000*100);
  document.getElementById('bar').style.width=pct+'%';
  document.getElementById('progressText').textContent='Postęp: '+(3000-leftQty)+'/3000 sztuk ('+pct+'%)';
}

function renderMap(){
  const map=document.getElementById('storeMap');
  map.querySelectorAll('.shelf').forEach(e=>e.remove());
  const groups=grouped();
  for(const s of SHELVES){
    const grp=groups.find(g=>g.key===s.key);
    const left=grp?grp.items.filter(x=>!x.done).length:0;
    const div=document.createElement('div');
    div.className='shelf '+(currentShelfKey===s.key?'active ':'')+(left===0?'done':'');
    div.style.left=s.x+'%'; div.style.top=s.y+'%';
    div.innerHTML=s.name+'<br><span class="small">'+left+' EAN</span>';
    map.appendChild(div);
  }
  drawPath();
}

function drawPath(){
  const svg=document.getElementById('pathSvg');
  const groups=grouped().filter(g=>g.items.some(x=>!x.done));
  const points=[{x:50,y:94}].concat(groups.map(g=>({x:g.x+13,y:g.y+9,key:g.key})));
  let html='';
  for(let i=0;i<points.length-1;i++)html+=`<line x1="${points[i].x}" y1="${points[i].y}" x2="${points[i+1].x}" y2="${points[i+1].y}"></line>`;
  for(const p of points)html+=`<circle cx="${p.x}" cy="${p.y}" r="2.5"></circle>`;
  svg.innerHTML=html;
}

function renderPallet(){
  const visual=document.getElementById('palletVisual');
  visual.innerHTML='';
  const maxBoxes=80;
  for(let i=0;i<Math.min(maxBoxes,PALLET_ITEMS.length);i++){
    const it=PALLET_ITEMS[i];
    const x=(i%10)*10+1, y=Math.floor(i/10)*26+7;
    const div=document.createElement('div');
    div.className='box '+it.shelfKey+(it.done?' done':'');
    div.style.left=x+'%'; div.style.top=y+'px'; div.style.width=(8+Math.min(13,it.cartons*2))+'%'; div.style.height='21px';
    div.textContent=it.done?'OK':it.cartons+'k';
    visual.appendChild(div);
  }
}

function currentShelfItems(){
  if(!currentShelfKey)return [];
  return PALLET_ITEMS.filter(x=>x.shelfKey===currentShelfKey && !x.done);
}

function renderTask(){
  const task=document.getElementById('task');
  const list=document.getElementById('currentList');
  const warning=document.getElementById('warning');
  warning.style.display='none';
  const left=PALLET_ITEMS.filter(x=>!x.done);
  if(left.length===0){
    task.innerHTML='<div class="big">Paleta gotowa</div><p class="small">Wszystkie produkty zostały odhaczone.</p>';
    list.innerHTML='';
    document.getElementById('summaryText').textContent='Rozłożono 3000 sztuk z palety '+document.getElementById('palletNo').value+'.';
    return;
  }
  if(!currentShelfKey){
    task.innerHTML='<p class="small">Podaj EAN z góry palety. Apka wybierze regał i poprowadzi Cię na miejsce.</p><div class="eanbox">Czekam na pierwszy EAN</div>';
    list.innerHTML='<p class="small">Najpierw podaj EAN z góry palety.</p>';
    return;
  }
  const items=currentShelfItems();
  const shelfName=PALLET_ITEMS.find(x=>x.shelfKey===currentShelfKey)?.shelf||currentShelfKey;
  if(items.length===0){
    currentShelfKey=null;
    renderTask();
    return;
  }
  const next=items[0];
  task.innerHTML=`<p class="small">Jedź / zostań przy regale:</p><div class="big">${shelfName}</div><p class="small">Na tym regale zostało: <b>${items.length} EAN</b>, razem <b>${items.reduce((s,x)=>s+x.qty,0)} szt.</b></p><div class="eanbox">Następny EAN: ${next.ean}</div>`;
  list.innerHTML=items.slice(0,14).map((it,i)=>`<div class="product ${i===0?'next':''}"><b>${it.name}</b><br><span class="small">EAN: ${it.ean} • pozycja ${it.position} • ${it.cartons} kart. = ${it.qty} szt.</span></div>`).join('')+(items.length>14?'<p class="small">...i kolejne pozycje.</p>':'');
}

function normalizeDigits(text){
  const map={'zero':'0','jeden':'1','jedna':'1','dwa':'2','dwie':'2','trzy':'3','cztery':'4','pięć':'5','piec':'5','sześć':'6','szesc':'6','siedem':'7','osiem':'8','dziewięć':'9','dziewiec':'9'};
  let out='';
  String(text||'').toLowerCase().split(/\s+/).forEach(w=>out += map[w] || w.replace(/\D/g,''));
  return out;
}

function handleEAN(raw){
  const digits=normalizeDigits(raw);
  if(!digits || digits.length<2)return;
  const item=PALLET_ITEMS.find(x=>!x.done && x.ean.endsWith(digits));
  if(!item){
    sayAndWarn('Nie znalazłem tego EAN-u na tej palecie.');
    return;
  }
  if(!currentShelfKey){
    currentShelfKey=item.shelfKey;
    speak('Ten towar idzie na regał '+item.shelf+'. Jedź do regału. Na tym regale jest '+currentShelfItems().length+' artykułów z palety.');
  } else if(item.shelfKey!==currentShelfKey){
    const still=currentShelfItems().length;
    sayAndWarn('Nie tutaj. Ten EAN idzie na '+item.shelf+'. Zostań przy obecnym regale, masz tu jeszcze '+still+' artykułów.');
    return;
  }
  item.done=true;
  scannedCount++;
  const leftHere=currentShelfItems().length;
  if(scannedCount%5===0 && leftHere>0){
    speak('Dobrze. Na tym regale zostało jeszcze '+leftHere+' artykułów.');
  } else if(leftHere>0){
    speak('Odhaczono. Zostało tutaj '+leftHere+'.');
  } else {
    speak('Regał zakończony. Podaj kolejny EAN z góry palety.');
    currentShelfKey=null;
  }
  renderAll();
  if(PALLET_ITEMS.every(x=>x.done)){
    speak('Paleta zakończona. Misja wykonana.');
    show('summary');
  }
}

function sayAndWarn(text){
  const w=document.getElementById('warning');
  w.textContent=text;
  w.style.display='block';
  speak(text);
  toast(text);
}

function demoSayNext(){
  let item=null;
  if(currentShelfKey)item=currentShelfItems()[0];
  if(!item)item=PALLET_ITEMS.find(x=>!x.done);
  if(item)handleEAN(item.ean);
}

function demoSayWrong(){
  if(!currentShelfKey){toast('Najpierw podaj dobry pierwszy EAN.');return;}
  const wrong=PALLET_ITEMS.find(x=>!x.done && x.shelfKey!==currentShelfKey);
  if(wrong)handleEAN(wrong.ean);
}

function toggleMic(){
  if(listening)stopMic(); else startMic();
}

function startMic(){
  if(!SR){alert('Mikrofon działa w Chrome przez HTTPS. Do lokalnego testu użyj przycisków demo.');return;}
  if(recognition)try{recognition.abort();}catch(e){}
  recognition=new SR(); recognition.lang='pl-PL'; recognition.continuous=false; recognition.interimResults=true; recognition.maxAlternatives=3;
  recognition.onstart=()=>{listening=true;updateMic(true);};
  recognition.onresult=(e)=>{
    let final='', interim='';
    for(let i=e.resultIndex;i<e.results.length;i++){const t=e.results[i][0].transcript;if(e.results[i].isFinal)final+=t;else interim+=t;}
    if(final)handleEAN(final);
  };
  recognition.onerror=()=>scheduleRestart(400);
  recognition.onend=()=>{if(listening)scheduleRestart(250);};
  try{recognition.start();}catch(e){scheduleRestart(500);}
}

function stopMic(){
  listening=false; clearTimeout(restartTimer); try{recognition&&recognition.abort();}catch(e){} updateMic(false);
}

function scheduleRestart(d){clearTimeout(restartTimer);if(listening)restartTimer=setTimeout(()=>startMic(),d);}
function updateMic(on){document.getElementById('micDot').className='dot '+(on?'on':'');document.getElementById('micStatus').textContent=on?'Nasłuchiwanie aktywne':'Mikrofon wyłączony';document.getElementById('micBtn').textContent=on?'Zatrzymaj mikrofon':'Włącz mikrofon';}

let plVoice=null;
function pickVoice(){if(!window.speechSynthesis)return;const v=speechSynthesis.getVoices();plVoice=v.find(x=>x.lang==='pl-PL')||v.find(x=>x.lang&&x.lang.startsWith('pl'))||null;}
if(window.speechSynthesis){pickVoice();speechSynthesis.onvoiceschanged=pickVoice;}
function speak(text){if(!window.speechSynthesis)return;speechSynthesis.cancel();const u=new SpeechSynthesisUtterance(String(text).replace(/_/g,' '));u.lang='pl-PL';u.rate=.96;if(plVoice)u.voice=plVoice;speechSynthesis.speak(u);}
function toast(t){const el=document.getElementById('toast');el.textContent=t;el.style.display='block';setTimeout(()=>el.style.display='none',2200);}
function resetAll(){currentShelfKey=null;scannedCount=0;PALLET_ITEMS.forEach(x=>x.done=false);renderAll();show('start');}

renderAll();
</script>
